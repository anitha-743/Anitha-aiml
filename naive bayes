{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyPuCwtYZIYv7erznZo/SYnF"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["#step 1:import libraries\n","import pandas as pd\n","from sklearn.preprocessing import LabelEncoder\n","from sklearn.naive_bayes import CategoricalNB\n","\n","\n","#step 2:create dataset\n","data={\n","    'weather':['sunny','sunny','rainy','rainy','cloudy','sunny','cloudy','rainy', 'sunny'],\n","    'soil':['humid','humid','humid','humid','humid','humid','humid','humid', 'dry'],\n","    'temperature':['hot','hot','hot','cold','cold','cold','cold','cold', 'cool'],\n","    'irrigate':['yes','no','yes','no','yes','no','yes','no', 'yes']\n","    }\n","df=pd.DataFrame(data)\n","print('Dataset:\\n',df)\n","\n","\n","#step 3:Encode categorical features\n","ie_weather=LabelEncoder()\n","ie_soil=LabelEncoder()\n","ie_temperature=LabelEncoder()\n","ie_target=LabelEncoder()\n","\n","df['weather']=ie_weather.fit_transform(df['weather'])\n","df['soil']=ie_soil.fit_transform(df['soil'])\n","df['temperature']=ie_temperature.fit_transform(df['temperature'])\n","df['irrigate']=ie_target.fit_transform(df['irrigate'])\n","\n","print('Encoded Dataset:\\n',df)\n","\n","\n","\n","#step 4:split feature and target\n","x=df[['weather','soil','temperature']]\n","y=df['irrigate']\n","\n","\n","#step 5: train naive bayes model\n","model=CategoricalNB()\n","model.fit(x,y)\n","\n","#step 6:test input(sunny,dry,cool)\n","test_data=pd.DataFrame({\n","    'weather':['sunny'],\n","    'soil':['dry'],\n","    'temperature':['cool']\n","})\n","#encode test data using same encoders\n","test_data['weather']=ie_weather.transform(test_data['weather'])\n","test_data['soil']=ie_soil.transform(test_data['soil'])\n","test_data['temperature']=ie_temperature.transform(test_data['temperature'])\n","\n","#step 7:prediction\n","prediction=model.predict(test_data)\n"